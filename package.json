{
  "name": "flamora-agri",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "cd apps/web && npm run dev",
    "dev:backend": "cd apps/api && npm run start:dev",
    "build": "npm run build:frontend && npm run build:backend",
    "build:frontend": "cd apps/web && npm run build",
    "build:backend": "cd apps/api && npm run build",
    "install:all": "npm install && cd apps/web && npm install && cd ../api && npm install"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
